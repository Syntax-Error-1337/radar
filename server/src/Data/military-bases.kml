					<description>This large facility is the primary basic training site for the Royal Navy. It&apos;s facilities include damage control and fire fighting trainers, additionally to this, former HMS brecon is moored as a static training ship.</description>
					<LookAt>
						<longitude>-4.220645312635276</longitude>
						<latitude>50.37366015208738</latitude>
						<altitude>0</altitude>
						<heading>-1.759955883550278</heading>
						<tilt>20.31857528916268</tilt>
						<range>1154.222120863343</range>
						<gx:altitudeMode>relativeToSeaFloor</gx:altitudeMode>
					</LookAt>
					<styleUrl>#msn_ferry3</styleUrl>
					<Point>
						<gx:drawOrder>1</gx:drawOrder>
						<coordinates>-4.222051792176089,50.37348791882616,0</coordinates>
					</Point>
				</Placemark>
				<Placemark>
					<name>HMS Sultan</name>
					<description>Primary training facility for the Royal Navy&apos;s engineers.</description>
					<LookAt>
						<longitude>-1.159492274882586</longitude>
						<latitude>50.79930060660539</latitude>
						<altitude>0</altitude>
						<heading>0.0006582475780523405</heading>
						<tilt>0</tilt>
						<range>1912.638092788277</range>
