					<Point>
						<gx:drawOrder>1</gx:drawOrder>
						<coordinates>125.8681740679258,39.28148906897882,0</coordinates>
					</Point>
				</Placemark>
				<Placemark>
					<name>Gorae (Sinpo) Class Ballistic Missile Submarine</name>
					<description>The sub is believed to be more of a testing platform for the future &quot;Sinpo Class C&quot; boats. It holds one Pukkuksong-1 ballistic missile. Pukkuksong translates to &quot;North Star&quot;, aka Polaris, aka the first submarine launched ballistic missile the US built, the UGM-27 Polaris, in the late 50s early 60s.</description>
					<LookAt>
						<longitude>128.1656007608519</longitude>
						<latitude>40.02554987850066</latitude>
						<altitude>0</altitude>
						<heading>0.9949943538872151</heading>
						<tilt>0</tilt>
						<range>407.4400460720519</range>
						<gx:altitudeMode>relativeToSeaFloor</gx:altitudeMode>
					</LookAt>
