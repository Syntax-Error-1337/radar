					</LookAt>
					<styleUrl>#msn_ferry3</styleUrl>
					<Point>
						<gx:drawOrder>1</gx:drawOrder>
						<coordinates>-1.162728567056643,50.80261761641892,0</coordinates>
					</Point>
				</Placemark>
				<Placemark>
					<name>Rosyth Dockyard</name>
					<description>Key construction and maintenance facility for the Royal Navy and BAE Systems. Both Queen Elizabeth Class Carriers assembled at Rosyth and a number of decomissioned submarines are moored here.</description>
					<LookAt>
						<longitude>-3.43798056122685</longitude>
