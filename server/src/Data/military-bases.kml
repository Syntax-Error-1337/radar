		<Folder>
			<name>Abkhazia</name>
			<Placemark>
				<name>Sokhumi</name>
				<description>Naval Headquarters and primary port of the Abkhazian Navy, operating 4 Shmel class boats.</description>
				<Camera>
					<longitude>41.02358283412555</longitude>
					<latitude>42.99647794367078</latitude>
					<altitude>789.4083588427926</altitude>
					<heading>-2.799944587705435</heading>
					<tilt>2.472243874798421</tilt>
					<roll>-1.704469884273748</roll>
					<gx:altitudeMode>relativeToSeaFloor</gx:altitudeMode>
				</Camera>
				<styleUrl>#m_ylw-pushpin</styleUrl>
				<Point>
					<gx:drawOrder>1</gx:drawOrder>
					<coordinates>41.02356238618451,42.99678375312654,0</coordinates>
				</Point>
			</Placemark>
			<Placemark>
				<name>Gudata</name>
				<description>Headquarters of the Russian forces based in Abkhazia, the airfield is largely disused but the base hosts some 3500 troops and T90 MBTs and BTR APCs.</description>
				<LookAt>
					<longitude>40.59175549888157</longitude>
					<latitude>43.10079044267933</latitude>
					<altitude>0</altitude>
					<heading>-1.615034270098853</heading>
					<tilt>18.26296481224051</tilt>
					<range>2207.595632211095</range>
					<gx:altitudeMode>relativeToSeaFloor</gx:altitudeMode>
				</LookAt>
				<styleUrl>#msn_truck</styleUrl>
				<Point>
					<gx:drawOrder>1</gx:drawOrder>
					<coordinates>40.58529973119737,43.09983288480062,0</coordinates>
				</Point>
			</Placemark>
			<Placemark>
				<name>Sokhumi Military Academy</name>
				<description>Sokhumi houses the core of the Abkhazian Armed Forces, with both the army command and military academy being based in the city.</description>
				<LookAt>
					<longitude>41.02173993688441</longitude>
					<latitude>43.00069724758652</latitude>
					<altitude>0</altitude>
					<heading>-10.71988656072538</heading>
					<tilt>14.31709274716504</tilt>
					<range>2622.657182094211</range>
					<gx:altitudeMode>relativeToSeaFloor</gx:altitudeMode>
				</LookAt>
				<styleUrl>#msn_truck</styleUrl>
				<Point>
					<gx:drawOrder>1</gx:drawOrder>
					<coordinates>41.01924194545353,43.00299318178861,0</coordinates>
				</Point>
			</Placemark>
			<Placemark>
				<name>Babushara</name>
				<description>Airfield of the Abkhazian Air Force. It is difficult to confirm the exact strength of the Air Force, different sources have suggested different levels of sophistication. This author believes;
5 x L39s
1 Su-25
1 Yak-52
3 x Mi-24
2 x Mi-8
2 x An-2</description>
				<Camera>
					<longitude>41.12849437317231</longitude>
					<latitude>42.86456600613235</latitude>
					<altitude>1121.825847355646</altitude>
					<heading>-91.6461094448823</heading>
					<tilt>0.2429561145184393</tilt>
					<roll>-89.60636779846004</roll>
					<gx:altitudeMode>relativeToSeaFloor</gx:altitudeMode>
				</Camera>
				<styleUrl>#msn_airports</styleUrl>
				<Point>
					<gx:drawOrder>1</gx:drawOrder>
					<coordinates>41.12264642973285,42.86387321609852,0</coordinates>
				</Point>
			</Placemark>
