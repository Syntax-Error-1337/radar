			<Folder>
				<name>Other Sites</name>
				<Placemark>
					<name>March 16th Factory</name>
					<description>Automobile factory. Also claimed to be building TELs (Transporter Erector Lauchers) to launch ballistic missiles. The Hwasong 15 ICBM test in late November 2017 was photographed in this factory, and test launched from a site nearby.</description>
					<LookAt>
						<longitude>125.8681740679258</longitude>
						<latitude>39.28148906897882</latitude>
						<altitude>0</altitude>
						<heading>-1.002083827330257</heading>
						<tilt>0</tilt>
						<range>954.2586953013055</range>
						<gx:altitudeMode>relativeToSeaFloor</gx:altitudeMode>
					</LookAt>
